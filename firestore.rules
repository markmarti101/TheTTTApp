rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: user owns their document
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Helper: get user role from users collection
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Helper: user is admin of a training company
    function isCompanyAdmin(companyId) {
      let company = get(/databases/$(database)/documents/training_companies/$(companyId)).data;
      return isAuth() && request.auth.uid in company.admins;
    }

    // Users: read own, write own (or admin creating)
    match /users/{userId} {
      allow read: if isAuth() && (request.auth.uid == userId || getUserRole() == 'training_company');
      allow create: if isAuth();
      allow update, delete: if isOwner(userId) ||
        (
          getUserRole() == 'training_company' &&
          resource.data.role == 'client' &&
          resource.data.companyId is string &&
          isCompanyAdmin(resource.data.companyId)
        ) ||
        // Allow a client to write their own companyId when claiming an invite.
        (
          isOwner(userId) &&
          request.resource.data.role == 'client'
        );

      // Delegates subcollection: owner only
      match /delegates/{delegateId} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }
    }

    // Training companies: create allowed for training_company users (self as admin); else admins only
    match /training_companies/{companyId} {
      allow create: if isAuth()
        // Do not rely on users/{uid}.role existing yet; self-owned create is allowed.
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.admins
        // Required onboarding fields
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.businessEmail is string
        && request.resource.data.businessEmail.size() > 0;
      // Allow read if user is in admins array, is the owner, or is a linked client/trainer.
      allow read: if isAuth() && (
        request.auth.uid in resource.data.admins ||
        resource.data.ownerId == request.auth.uid ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId
        )
      );
      allow update, delete: if isAuth() && isCompanyAdmin(companyId);
    }

    // Freelance trainers: own profile or company admin
    match /freelance_trainers/{trainerId} {
      allow read: if isAuth() && (request.auth.uid == trainerId || getUserRole() == 'training_company');
      allow create, update, delete: if isOwner(trainerId);
    }

    // Clients: own profile or company admin
    match /clients/{clientId} {
      allow read: if isAuth() && (request.auth.uid == clientId || getUserRole() == 'training_company');
      allow create, update, delete: if isAuth() && (isOwner(clientId) || getUserRole() == 'training_company');
    }

    // Course requests: company admins or client (creator)
    match /course_requests/{requestId} {
      allow read: if isAuth() && (
        isCompanyAdmin(resource.data.trainingCompanyId) ||
        request.auth.uid == resource.data.clientId
      );
      allow create: if isAuth() && (
        request.auth.uid == request.resource.data.clientId ||
        isCompanyAdmin(request.resource.data.trainingCompanyId)
      );
      allow update, delete: if isAuth() && (
        isCompanyAdmin(resource.data.trainingCompanyId) ||
        request.auth.uid == resource.data.clientId
      );
    }

    // Client invites: created by company admins, claimed by invited client account
    match /client_invites/{inviteId} {
      // Individual document read: only company admin or client role.
      allow get: if isAuth() && (
        isCompanyAdmin(resource.data.companyId) ||
        getUserRole() == 'client'
      );
      // List queries (e.g. where email == x): allowed for training company admins
      // and clients. App-level code is responsible for scoping queries correctly.
      allow list: if isAuth() && (
        getUserRole() == 'training_company' ||
        getUserRole() == 'client'
      );

      allow create: if isAuth() &&
        getUserRole() == 'training_company' &&
        request.resource.data.companyId is string &&
        isCompanyAdmin(request.resource.data.companyId) &&
        request.resource.data.status == 'pending' &&
        request.resource.data.email is string &&
        request.resource.data.email.size() > 3;

      allow update: if isAuth() && (
        // Company admin can maintain pending invites for their company
        (
          getUserRole() == 'training_company' &&
          resource.data.companyId is string &&
          isCompanyAdmin(resource.data.companyId)
        ) ||
        // Client can only claim a pending invite and only for themselves
        (
          getUserRole() == 'client' &&
          resource.data.status == 'pending' &&
          request.resource.data.status == 'claimed' &&
          request.resource.data.claimedByUid == request.auth.uid &&
          request.resource.data.companyId == resource.data.companyId &&
          request.resource.data.email == resource.data.email
        )
      );

      allow delete: if isAuth() &&
        getUserRole() == 'training_company' &&
        resource.data.companyId is string &&
        isCompanyAdmin(resource.data.companyId);
    }

    // Trainer invites: created by company admins, claimed by invited trainer account
    match /trainer_invites/{inviteId} {
      allow get: if isAuth() && (
        isCompanyAdmin(resource.data.companyId) ||
        getUserRole() == 'freelance_trainer'
      );
      allow list: if isAuth() && (
        getUserRole() == 'training_company' ||
        getUserRole() == 'freelance_trainer'
      );

      allow create: if isAuth() &&
        getUserRole() == 'training_company' &&
        request.resource.data.companyId is string &&
        isCompanyAdmin(request.resource.data.companyId) &&
        request.resource.data.status == 'pending' &&
        request.resource.data.email is string &&
        request.resource.data.email.size() > 3;

      allow update: if isAuth() && (
        // Company admin can maintain pending invites for their company
        (
          getUserRole() == 'training_company' &&
          resource.data.companyId is string &&
          isCompanyAdmin(resource.data.companyId)
        ) ||
        // Trainer can accept (claim) or decline a pending invite
        (
          getUserRole() == 'freelance_trainer' &&
          resource.data.status == 'pending' &&
          (request.resource.data.status == 'claimed' || request.resource.data.status == 'declined') &&
          request.resource.data.companyId == resource.data.companyId &&
          request.resource.data.email == resource.data.email &&
          (request.resource.data.status == 'declined' ||
            request.resource.data.claimedByUid == request.auth.uid)
        )
      );

      allow delete: if isAuth() &&
        getUserRole() == 'training_company' &&
        resource.data.companyId is string &&
        isCompanyAdmin(resource.data.companyId);
    }

    // Courses: company admins, assigned trainer, or client
    match /courses/{courseId} {
      allow read: if isAuth() && (
        isCompanyAdmin(resource.data.trainingCompanyId) ||
        request.auth.uid == resource.data.trainerId ||
        request.auth.uid == resource.data.clientId
      );
      allow create: if isAuth() && isCompanyAdmin(request.resource.data.trainingCompanyId);
      allow update: if isAuth() && (
        isCompanyAdmin(resource.data.trainingCompanyId) ||
        // Trainer can accept or decline a job assigned to them
        (
          request.auth.uid == resource.data.trainerId &&
          resource.data.status == 'pending_trainer' &&
          (request.resource.data.status == 'confirmed' || request.resource.data.status == 'trainer_declined') &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
        ) ||
        // Client can set their own PO number
        (
          request.auth.uid == resource.data.clientId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['poNumber', 'updatedAt'])
        )
      );
      allow delete: if isAuth() && isCompanyAdmin(resource.data.trainingCompanyId);
    }

    // Venues: company admins, linked clients, or client-owned
    match /venues/{venueId} {
      allow read: if isAuth() && (
        isCompanyAdmin(resource.data.trainingCompanyId) ||
        request.auth.uid == resource.data.clientId ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == resource.data.trainingCompanyId
        )
      );
      allow create: if isAuth() && isCompanyAdmin(request.resource.data.trainingCompanyId);
      allow update, delete: if isAuth() && isCompanyAdmin(resource.data.trainingCompanyId);
    }

    // Resources: company admins only
    match /resources/{resourceId} {
      allow create: if isAuth() && isCompanyAdmin(request.resource.data.trainingCompanyId);
      allow read, update, delete: if isAuth() && isCompanyAdmin(resource.data.trainingCompanyId);
    }

    // Resource allocations: company admins only
    match /resource_allocations/{allocationId} {
      allow create: if isAuth() && isCompanyAdmin(request.resource.data.trainingCompanyId);
      allow read, delete: if isAuth() && isCompanyAdmin(resource.data.trainingCompanyId);
      allow update: if false;
    }

    // Documents: uploader, assigned trainer/client on the course, or company admin
    match /documents/{docId} {
      // Single-document get: full cross-collection validation
      allow get: if isAuth() && (
        request.auth.uid == resource.data.uploadedBy ||
        isCompanyAdmin(resource.data.trainingCompanyId) ||
        (
          exists(/databases/$(database)/documents/courses/$(resource.data.courseId)) &&
          (
            get(/databases/$(database)/documents/courses/$(resource.data.courseId)).data.trainerId == request.auth.uid ||
            get(/databases/$(database)/documents/courses/$(resource.data.courseId)).data.clientId == request.auth.uid
          )
        )
      );
      // List (query) operations: company admins and trainers by role;
      // clients must query with clientId filter so the rule can be validated.
      allow list: if isAuth() && (
        getUserRole() == 'training_company' ||
        getUserRole() == 'freelance_trainer' ||
        request.auth.uid == resource.data.clientId
      );
      allow create: if isAuth() && request.auth.uid == request.resource.data.uploadedBy;
      allow delete: if isAuth() && (
        request.auth.uid == resource.data.uploadedBy ||
        isCompanyAdmin(resource.data.trainingCompanyId)
      );
      allow update: if false;
    }

    // Notifications: each user reads/writes their own
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.recipientId == request.auth.uid;
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.recipientId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if false;
    }

    // Trainer profiles: trainer owns, training companies can read main doc only
    match /trainer_profiles/{trainerId} {
      allow read: if isAuth() && (
        request.auth.uid == trainerId ||
        getUserRole() == 'training_company'
      );
      allow write: if isAuth() && request.auth.uid == trainerId;

      // Private subcollection (banking details): owner only
      match /private/{docId} {
        allow read, write: if isAuth() && request.auth.uid == trainerId;
      }

      // Course notes: owner only
      match /course_notes/{courseId} {
        allow read, write: if isAuth() && request.auth.uid == trainerId;
      }
    }

    // Trainer rates: company admins set rates per trainer
    match /trainer_rates/{rateId} {
      allow read: if isAuth() && (
        isCompanyAdmin(resource.data.companyId) ||
        request.auth.uid == resource.data.trainerId
      );
      allow create: if isAuth() &&
        isCompanyAdmin(request.resource.data.companyId);
      allow update: if isAuth() &&
        isCompanyAdmin(resource.data.companyId);
      allow delete: if false;
    }

    // Audit log: read-only for company admins, write via backend/Cloud Functions
    match /audit_log/{logId} {
      allow read: if isAuth() && getUserRole() == 'training_company';
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // Client pricing: company admins set custom rates per client
    match /client_pricing/{docId} {
      allow read: if isAuth() && (
        isCompanyAdmin(resource.data.companyId) ||
        request.auth.uid == resource.data.clientId
      );
      allow create: if isAuth() &&
        isCompanyAdmin(request.resource.data.companyId);
      allow update: if isAuth() &&
        isCompanyAdmin(resource.data.companyId);
      allow delete: if false;
    }

    // Course feedback: client submits once, company can read
    match /course_feedback/{courseId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.clientId ||
        isCompanyAdmin(resource.data.trainingCompanyId)
      );
      allow create: if isAuth() &&
        request.auth.uid == request.resource.data.clientId;
      allow update: if isAuth() &&
        request.auth.uid == resource.data.clientId;
      allow delete: if false;
    }
  }
}
