rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Documents: caller must belong to the same tenant as the path's companyId
    match /documents/{companyId}/{courseId}/{type}/{fileName} {
      allow read: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.companyId == companyId;
      allow write: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.companyId == companyId
        && request.resource.size < 25 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf|image/(png|jpeg|webp)');
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
