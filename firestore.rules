rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: user owns their document
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Helper: get user role from users collection
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Helper: user is admin of a training company
    function isCompanyAdmin(companyId) {
      let company = get(/databases/$(database)/documents/training_companies/$(companyId)).data;
      return isAuth() && request.auth.uid in company.admins;
    }

    // Users: read own, write own (or admin creating)
    match /users/{userId} {
      allow read: if isAuth() && (request.auth.uid == userId || getUserRole() == 'training_company');
      allow create: if isAuth();
      allow update, delete: if isOwner(userId) ||
        (
          getUserRole() == 'training_company' &&
          resource.data.role == 'client' &&
          resource.data.companyId is string &&
          isCompanyAdmin(resource.data.companyId)
        ) ||
        // Allow a client to write their own companyId when claiming an invite.
        (
          isOwner(userId) &&
          request.resource.data.role == 'client'
        );
    }

    // Training companies: create allowed for training_company users (self as admin); else admins only
    match /training_companies/{companyId} {
      allow create: if isAuth()
        // Do not rely on users/{uid}.role existing yet; self-owned create is allowed.
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.admins
        // Required onboarding fields
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.businessEmail is string
        && request.resource.data.businessEmail.size() > 0;
      // Allow read if user is in admins array, is the owner, or is a linked client/trainer.
      allow read: if isAuth() && (
        request.auth.uid in resource.data.admins ||
        resource.data.ownerId == request.auth.uid ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId
        )
      );
      allow update, delete: if isAuth() && isCompanyAdmin(companyId);
    }

    // Freelance trainers: own profile or company admin
    match /freelance_trainers/{trainerId} {
      allow read: if isAuth() && (request.auth.uid == trainerId || getUserRole() == 'training_company');
      allow create, update, delete: if isOwner(trainerId);
    }

    // Clients: own profile or company admin
    match /clients/{clientId} {
      allow read: if isAuth() && (request.auth.uid == clientId || getUserRole() == 'training_company');
      allow create, update, delete: if isAuth() && (isOwner(clientId) || getUserRole() == 'training_company');
    }

    // Course requests: company admins or client (creator)
    match /course_requests/{requestId} {
      allow read: if isAuth() && (
        isCompanyAdmin(resource.data.trainingCompanyId) ||
        request.auth.uid == resource.data.clientId
      );
      allow create: if isAuth() && (
        request.auth.uid == request.resource.data.clientId ||
        isCompanyAdmin(request.resource.data.trainingCompanyId)
      );
      allow update, delete: if isAuth() && (
        isCompanyAdmin(resource.data.trainingCompanyId) ||
        request.auth.uid == resource.data.clientId
      );
    }

    // Client invites: created by company admins, claimed by invited client account
    match /client_invites/{inviteId} {
      // Individual document read: only company admin or client role.
      allow get: if isAuth() && (
        isCompanyAdmin(resource.data.companyId) ||
        getUserRole() == 'client'
      );
      // List queries (e.g. where email == x): allowed for training company admins
      // and clients. App-level code is responsible for scoping queries correctly.
      allow list: if isAuth() && (
        getUserRole() == 'training_company' ||
        getUserRole() == 'client'
      );

      allow create: if isAuth() &&
        getUserRole() == 'training_company' &&
        request.resource.data.companyId is string &&
        isCompanyAdmin(request.resource.data.companyId) &&
        request.resource.data.status == 'pending' &&
        request.resource.data.email is string &&
        request.resource.data.email.size() > 3;

      allow update: if isAuth() && (
        // Company admin can maintain pending invites for their company
        (
          getUserRole() == 'training_company' &&
          resource.data.companyId is string &&
          isCompanyAdmin(resource.data.companyId)
        ) ||
        // Client can only claim a pending invite and only for themselves
        (
          getUserRole() == 'client' &&
          resource.data.status == 'pending' &&
          request.resource.data.status == 'claimed' &&
          request.resource.data.claimedByUid == request.auth.uid &&
          request.resource.data.companyId == resource.data.companyId &&
          request.resource.data.email == resource.data.email
        )
      );

      allow delete: if isAuth() &&
        getUserRole() == 'training_company' &&
        resource.data.companyId is string &&
        isCompanyAdmin(resource.data.companyId);
    }

    // Courses: company admins, assigned trainer, or client
    match /courses/{courseId} {
      allow read: if isAuth() && (
        isCompanyAdmin(resource.data.trainingCompanyId) ||
        request.auth.uid == resource.data.trainerId ||
        request.auth.uid == resource.data.clientId
      );
      allow create: if isAuth() && isCompanyAdmin(request.resource.data.trainingCompanyId);
      allow update, delete: if isAuth() && isCompanyAdmin(resource.data.trainingCompanyId);
    }

    // Venues: company admins, linked clients, or client-owned
    match /venues/{venueId} {
      allow read: if isAuth() && (
        isCompanyAdmin(resource.data.trainingCompanyId) ||
        request.auth.uid == resource.data.clientId ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == resource.data.trainingCompanyId
        )
      );
      allow create: if isAuth() && isCompanyAdmin(request.resource.data.trainingCompanyId);
      allow update, delete: if isAuth() && isCompanyAdmin(resource.data.trainingCompanyId);
    }

    // Resources: company admins only
    match /resources/{resourceId} {
      allow create: if isAuth() && isCompanyAdmin(request.resource.data.trainingCompanyId);
      allow read, update, delete: if isAuth() && isCompanyAdmin(resource.data.trainingCompanyId);
    }

    // Documents: owner or related entity access
    match /documents/{docId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.ownerId ||
        getUserRole() == 'training_company'
      );
      allow create: if isAuth();
      allow update, delete: if isAuth() && request.auth.uid == resource.data.ownerId;
    }

    // Audit log: read-only for company admins, write via backend/Cloud Functions
    match /audit_log/{logId} {
      allow read: if isAuth() && getUserRole() == 'training_company';
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // Course feedback: client submits once, company can read
    match /course_feedback/{courseId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.clientId ||
        isCompanyAdmin(resource.data.trainingCompanyId)
      );
      allow create: if isAuth() &&
        request.auth.uid == request.resource.data.clientId;
      allow update: if isAuth() &&
        request.auth.uid == resource.data.clientId;
      allow delete: if false;
    }
  }
}
