rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: user owns their document
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Helper: get user role from users collection
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Helper: user is admin of a training company
    function isCompanyAdmin(companyId) {
      let company = get(/databases/$(database)/documents/training_companies/$(companyId)).data;
      return isAuth() && request.auth.uid in company.admins;
    }

    // Users: read own, write own (or admin creating)
    match /users/{userId} {
      allow read: if isAuth() && (request.auth.uid == userId || getUserRole() == 'training_company');
      allow create: if isAuth();
      allow update, delete: if isOwner(userId);
    }

    // Training companies: admins only
    match /training_companies/{companyId} {
      allow read, write: if isAuth() && isCompanyAdmin(companyId);
    }

    // Freelance trainers: own profile or company admin
    match /freelance_trainers/{trainerId} {
      allow read: if isAuth() && (request.auth.uid == trainerId || getUserRole() == 'training_company');
      allow create, update, delete: if isOwner(trainerId);
    }

    // Clients: own profile or company admin
    match /clients/{clientId} {
      allow read: if isAuth() && (request.auth.uid == clientId || getUserRole() == 'training_company');
      allow create, update, delete: if isAuth() && (isOwner(clientId) || getUserRole() == 'training_company');
    }

    // Courses: company admins, assigned trainer, or client
    match /courses/{courseId} {
      allow read: if isAuth() && (
        isCompanyAdmin(resource.data.trainingCompanyId) ||
        request.auth.uid == resource.data.trainerId ||
        request.auth.uid == resource.data.clientId
      );
      allow create: if isAuth() && isCompanyAdmin(request.resource.data.trainingCompanyId);
      allow update, delete: if isAuth() && isCompanyAdmin(resource.data.trainingCompanyId);
    }

    // Venues: company admins or client (if client-owned)
    match /venues/{venueId} {
      allow read: if isAuth() && (
        isCompanyAdmin(resource.data.trainingCompanyId) ||
        request.auth.uid == resource.data.clientId
      );
      allow create: if isAuth() && isCompanyAdmin(request.resource.data.trainingCompanyId);
      allow update, delete: if isAuth() && isCompanyAdmin(resource.data.trainingCompanyId);
    }

    // Resources: company admins only
    match /resources/{resourceId} {
      allow create: if isAuth() && isCompanyAdmin(request.resource.data.trainingCompanyId);
      allow read, update, delete: if isAuth() && isCompanyAdmin(resource.data.trainingCompanyId);
    }

    // Documents: owner or related entity access
    match /documents/{docId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.ownerId ||
        getUserRole() == 'training_company'
      );
      allow create: if isAuth();
      allow update, delete: if isAuth() && request.auth.uid == resource.data.ownerId;
    }

    // Audit log: read-only for company admins, write via backend/Cloud Functions
    match /audit_log/{logId} {
      allow read: if isAuth() && getUserRole() == 'training_company';
      allow create: if isAuth();
      allow update, delete: if false;
    }
  }
}
