{
  "name": "training-triangle-app",
  "version": "0.1.0",
  "private": true,
  "description": "Training management platform for Training Companies, Freelance Trainers, and Clients",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:shared": "npm run build -w @training-triangle/shared",
    "dev:api": "npm run dev -w @training-triangle/api",
    "dev:web": "npm run dev -w @training-triangle/web",
    "dev:mobile": "npm run start -w @training-triangle/mobile",
    "build:api": "npm run build -w @training-triangle/api",
    "build:web": "npm run build -w @training-triangle/web",
    "build:mobile": "npm run build -w @training-triangle/mobile",
    "build": "npm run build:api && npm run build:web",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "training",
    "education",
    "scheduling",
    "freelance-trainers",
    "compliance"
  ],
  "author": "",
  "license": "UNLICENSED"
}
